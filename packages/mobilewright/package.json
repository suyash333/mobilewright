{
  "name": "mobilewright",
  "version": "0.0.1",
  "description": "Mobile device automation framework inspired by Playwright",
  "homepage": "https://mobilewright.dev",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "tsc -b"
  },
  "bin": {
    "mobilewright": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mobile-next/mobilewright.git",
    "directory": "packages/mobilewright"
  },
  "files": [
    "dist",
    "assets",
    "templates"
  ],
  "dependencies": {
    "@mobilewright/agent": "^0.0.1",
    "@mobilewright/core": "^0.0.1",
    "@mobilewright/driver-mobilecli": "^0.0.1",
    "@mobilewright/driver-mobilenext": "^0.0.1",
    "@mobilewright/inspector": "^0.0.1",
    "@mobilewright/protocol": "^0.0.1",
    "commander": "^14.0.3",
    "open": "^10.2.0",
    "debug": "^4.4.3",
    "playwright": "1.58.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0"
  }
}
